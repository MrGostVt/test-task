{
  "name": "test-task",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "turbo-dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "dev": "npm run dev ---workspaces"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.1",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@apollo/server": "^5.0.0"
  }
}
